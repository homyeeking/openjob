{
  "name": "openjob",
  "version": "1.0.6",
  "description": "Out of loop scheduled task system for AI agents",
  "packageManager": "pnpm@10.33.2",
  "files": [
    "bin/",
    "lib/",
    "dashboard/dist/"
  ],
  "bin": {
    "openjob": "bin/openjob"
  },
  "scripts": {
    "build": "tsc && pnpm --dir dashboard build",
    "build:cli": "tsc",
    "build:dashboard": "pnpm --dir dashboard build",
    "test:cli": "vitest run",
    "watch": "tsc --watch",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HomyeeKing/openjob.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/HomyeeKing/openjob/tree/master/cli",
  "bugs": {
    "url": "https://github.com/HomyeeKing/openjob/issues"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
